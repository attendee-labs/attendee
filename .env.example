# Attendee Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED - Core Settings
# =============================================================================

# Django secret key - generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Django settings module
DJANGO_SETTINGS_MODULE=attendee.settings.development

# Credentials encryption key for storing sensitive data
CREDENTIALS_ENCRYPTION_KEY=your-encryption-key-here

# =============================================================================
# DATABASE
# =============================================================================

# For development (devcontainer)
POSTGRES_HOST=localhost

# For production (use DATABASE_URL instead)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# =============================================================================
# REDIS / CELERY
# =============================================================================

# Local development
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# Google Cloud Memorystore (production)
# Format: redis://MEMORYSTORE_IP:6379
# Example: REDIS_URL=redis://10.0.0.3:6379
# Note: Memorystore uses private IPs - requires VPC connector for Cloud Run

# Redis SSL settings (for Redis providers that require SSL, NOT Memorystore)
# REDIS_SSL_REQUIREMENTS=none
# DISABLE_REDIS_SSL=false

# Redis Cluster support (for Memorystore Redis Cluster)
# Required to prevent CROSSSLOT errors with Redis Cluster
# CELERY_BROKER_TRANSPORT_OPTIONS={"global_keyprefix":"{celeryattendee}:","fanout_prefix":true,"fanout_patterns":true}

# =============================================================================
# STORAGE (S3 or Azure)
# =============================================================================

STORAGE_PROTOCOL=s3

# AWS S3 Settings
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_RECORDING_STORAGE_BUCKET_NAME=
AWS_AUDIO_CHUNK_STORAGE_BUCKET_NAME=
# AWS_ENDPOINT_URL=  # For S3-compatible services like MinIO

# Azure Blob Storage Settings (alternative to S3)
# AZURE_CONNECTION_STRING=
# AZURE_ACCOUNT_NAME=
# AZURE_ACCOUNT_KEY=
# AZURE_RECORDING_STORAGE_CONTAINER_NAME=
# AZURE_AUDIO_CHUNK_STORAGE_CONTAINER_NAME=

# Audio chunk settings
USE_REMOTE_STORAGE_FOR_AUDIO_CHUNKS=false
FALLBACK_TO_DB_STORAGE_FOR_AUDIO_CHUNKS_IF_REMOTE_STORAGE_FAILS=false

# =============================================================================
# EMAIL (Production) - Uses Postmark SMTP
# =============================================================================

# Postmark Server API Token (used as both username and password for SMTP)
POSTMARK_API_TOKEN=
DEFAULT_FROM_EMAIL=noreply@oppy.pro
SERVER_EMAIL=noreply@oppy.pro
# ERROR_REPORTS_RECEIVER_EMAIL_ADDRESS=

# To disable email sending entirely:
# DISABLE_EMAIL=true

# =============================================================================
# BOT CONFIGURATION
# =============================================================================

# Bot launch method: kubernetes, docker-compose-multi-host, or local
LAUNCH_BOT_METHOD=local

# Kubernetes namespaces (for k8s deployment)
BOT_POD_NAMESPACE=attendee
WEBPAGE_STREAMER_POD_NAMESPACE=attendee-webpage-streamer

# Bot pod settings
# IS_A_BOT_POD=false
# CONSERVE_BOT_POD_REDIS_CONNECTIONS=false
# BOT_POD_CELERY_BROKER_POOL_LIMIT=1

# Chrome sandbox (disable for Docker)
ENABLE_CHROME_SANDBOX=false

# =============================================================================
# CELERY QUEUES (Optional - defaults to 'celery')
# =============================================================================

# PROCESS_UTTERANCE_CELERY_QUEUE=celery
# PROCESS_ASYNC_TRANSCRIPTION_CELERY_QUEUE=celery
# SYNC_CALENDAR_CELERY_QUEUE=celery
# LAUNCH_SCHEDULED_BOT_CELERY_QUEUE=celery
# DELIVER_WEBHOOK_CELERY_QUEUE=celery

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Disable new user signups
# DISABLE_SIGNUP=false

# Charge credits for bot usage
CHARGE_CREDITS_FOR_BOTS=false

# Webhook settings
REQUIRE_HTTPS_WEBHOOKS=false

# Metadata settings
REQUIRE_STRING_VALUES_IN_METADATA=true
MAX_METADATA_LENGTH=1000

# Rate limiting
DISABLE_RATE_LIMITING=true
# PROJECT_POST_THROTTLE_RATE=3000/min

# =============================================================================
# LOGGING
# =============================================================================

ATTENDEE_LOG_LEVEL=INFO
# ATTENDEE_LOG_FORMAT=json
MASK_TRANSCRIPT_IN_LOGS=false

# =============================================================================
# SECURITY (Production)
# =============================================================================

# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
# CSRF_TRUSTED_ORIGINS=https://*.attendee.dev

# =============================================================================
# SITE SETTINGS
# =============================================================================

# For local development:
SITE_DOMAIN=localhost:8000
# For production (Cloud Run):
# SITE_DOMAIN=attendee-web-883356951770.us-west2.run.app
TIME_ZONE=UTC

# =============================================================================
# ROLLBAR (Optional - Error Tracking)
# =============================================================================

# ROLLBAR_ACCESS_TOKEN=
# ROLLBAR_ENVIRONMENT=development

# =============================================================================
# SENTRY (Optional - Error Tracking)
# =============================================================================

# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
